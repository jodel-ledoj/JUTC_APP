# Database
DATABASE_URL=postgresql://jutc_user:password@localhost:5432/jutc_db

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars-here-replace-this
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-replace-this
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# App
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# QR Tickets
QR_SECRET=your-qr-signing-secret-replace-this

# Push Notifications (Expo)
EXPO_ACCESS_TOKEN=

# SMS Fallback (Jamaica carriers)
DIGICEL_SMS_API_KEY=
FLOW_SMS_API_KEY=
