{
  "name": "jutc-digital",
  "private": true,
  "packageManager": "npm@10.8.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:migrate": "npm run db:migrate --workspace=@jutc/backend",
    "db:seed": "npm run db:seed --workspace=@jutc/backend"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "react-native-maps": "^1.14.0",
    "react-native-svg": "^15.2.0"
  }
}
