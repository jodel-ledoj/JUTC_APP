{
  "expo": {
    "name": "JUTC Digital",
    "slug": "jutc-digital",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.jutc.digital",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "VIBRATE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCeDAA_IkAe2FOpNEFqnt98FuapfYji2LI"
        }
      }
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jutc.digital",
      "config": {
        "googleMapsApiKey": "AIzaSyCeDAA_IkAe2FOpNEFqnt98FuapfYji2LI"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "JUTC needs your location for GPS tracking and nearby bus stops.",
        "NSLocationAlwaysUsageDescription": "Driver mode requires background location for GPS reporting."
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow JUTC Digital to use your location."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2F80ED",
          "sounds": []
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "jutc"
  }
}
